{
  "name": "speedtest",
  "version": "1.0.0",
  "description": "A simple network speed test website (download, upload, ping)",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "test:api": "node --test test/api.test.js",
    "test:e2e": "playwright test",
    "test:all": "npm run test:api && npm run test:e2e",
    "format": "prettier --write ."
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prettier": "^3.9.0"
  }
}
